{
  "_comment": "Plugin-scoped hooks. Merged with user ~/.claude/settings.json at load time. Fires after NotebookLM source_add, download_artifact, and studio_create MCP calls to keep the Notion Tracker DBs in sync. Controlled by NOTION_SYNC env var (set to 1 in D:/NotebookLM/.env).",
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "mcp__notebooklm-mcp__download_artifact|mcp__NotebookLM_MCP_Server__download_artifact",
        "hooks": [
          {
            "type": "command",
            "command": "python D:/NotebookLM/.claude/hooks/post_tool_use.py",
            "timeout": 180
          }
        ]
      },
      {
        "matcher": "mcp__notebooklm-mcp__source_add|mcp__NotebookLM_MCP_Server__source_add",
        "hooks": [
          {
            "type": "command",
            "command": "python D:/NotebookLM/.claude/hooks/post_tool_use.py",
            "timeout": 180
          }
        ]
      },
      {
        "matcher": "mcp__notebooklm-mcp__studio_create|mcp__NotebookLM_MCP_Server__studio_create",
        "hooks": [
          {
            "type": "command",
            "command": "python D:/NotebookLM/.claude/hooks/post_tool_use.py",
            "timeout": 180
          }
        ]
      }
    ]
  }
}
